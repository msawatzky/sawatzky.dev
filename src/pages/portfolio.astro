---
import { ArrowRight, ExternalLink } from "lucide-react";
import Layout from "../layouts/Layout.astro";
import sdLogo from "../assets/sd-logo-cropped.png";

const projects = [
  {
    title: "Jasper resort golf (demo)",
    tagline:
      "Concept site: resort storytelling, mountain golf positioning, and performance — not an endorsement by the venue.",
    url: "https://jasper-mountain-golf.pages.dev/",
    badge: "Concept / not a client",
    linkLabel: "Open demo",
  },
  {
    title: "Edmonton Springs Golf Course",
    tagline: "Spruce Grove public course — tee times, leagues, and local trust.",
    url: "https://edmonton-springs-golf.pages.dev/",
    badge: null as string | null,
    linkLabel: "Visit live site",
  },
];
---

<Layout
  title="Portfolio | Sawatzky Development"
  description="Recent custom Astro sites: live work and labeled concept demos on Cloudflare Pages."
>
  <section class="mx-auto w-full max-w-6xl px-4 pb-6 pt-14 sm:px-6 sm:pt-20 lg:px-8 lg:pt-24">
    <p class="text-sm font-semibold uppercase tracking-[0.14em] text-sky-200">Proof</p>
    <h1 class="mt-3 max-w-3xl text-4xl font-semibold leading-tight text-white sm:text-5xl">
      Recent work
    </h1>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-zinc-300 sm:text-lg">
      Custom builds focused on clarity, speed, and conversion. Concept demos are labeled so expectations stay honest.
    </p>
    <a
      href="#"
      data-contact-open
      class="mt-8 inline-flex items-center gap-2 rounded-md bg-sky-300 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-sky-200"
    >
      Book a Consultation
      <ArrowRight class="h-4 w-4" />
    </a>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pb-20 sm:px-6 lg:px-8">
    <div class="grid gap-6 md:grid-cols-2">
      {
        projects.map((p) => (
          <article
            class:list={[
              "flex flex-col rounded-2xl border p-6 sm:p-8",
              p.badge ? "border-amber-900/50 bg-slate-900/70" : "border-sky-900/50 bg-slate-900/70",
            ]}
          >
            <div class="flex flex-wrap items-start justify-between gap-2">
              <h2 class="text-xl font-semibold text-white">{p.title}</h2>
              {p.badge && (
                <span class="shrink-0 rounded-full border border-amber-500/40 bg-amber-500/10 px-2 py-0.5 text-[0.65rem] font-semibold uppercase tracking-wide text-amber-200">
                  {p.badge}
                </span>
              )}
            </div>
            <p class="mt-2 text-sm leading-relaxed text-zinc-300">{p.tagline}</p>
            <a
              href={p.url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-sky-200 transition hover:text-sky-100"
            >
              {p.linkLabel}
              <ExternalLink class="h-4 w-4" />
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <footer class="border-t border-slate-800">
    <div class="mx-auto flex w-full max-w-6xl flex-col gap-2 px-4 py-6 text-sm text-zinc-400 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
      <p class="inline-flex items-center gap-2">
        <img src={sdLogo.src} alt="SD monogram" class="h-5 w-5 object-contain" loading="lazy" />
        Built with Astro in Spruce Grove, AB
      </p>
      <a href="https://sawatzky.dev" class="text-sky-200 underline-offset-4 hover:underline">sawatzky.dev</a>
    </div>
  </footer>
</Layout>
